<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.2" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd">
  <persistence-unit name="DogosObregonPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
    <class>com.mycompany.dominio.Cliente</class>
    <class>com.mycompany.dominio.HotDog</class>
    <class>com.mycompany.dominio.Pedido</class>
    <class>com.mycompany.dominio.PedidoDetalle</class>
    <properties>
        <!-- PROPIEDAD PARA DETECTAR LAS ENTIDADES DENTRO DE DOMINIO AUNQUE ESTEN EN OTRO JAR<!-->
      <property name="hibernate.scan.packages" value="com.mycompany.dominio"/>
      
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/dogosobregondb?zeroDateTimeBehavior=CONVERT_TO_NULL"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.password" value="1234"/>
      <property name="hibernate.cache.provider_class" value="org.hibernate.cache.NoCacheProvider"/>
      <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
    </properties>
  </persistence-unit>
</persistence>
